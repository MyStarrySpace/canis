{
  "name": "@untangling/mechanistic-graph",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js",
      "default": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build crates/graph-engine --target web --out-dir ../../pkg",
    "build:ts": "tsup",
    "build:copy-wasm": "node -e \"require('fs').copyFileSync('pkg/graph_engine_bg.wasm','dist/graph_engine_bg.wasm')\"",
    "build": "npm run build:wasm && npm run build:ts && npm run build:copy-wasm",
    "test": "vitest run",
    "test:wasm": "wasm-pack test --node crates/graph-engine"
  },
  "peerDependencies": {
    "@xyflow/react": "^12",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@xyflow/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  }
}
